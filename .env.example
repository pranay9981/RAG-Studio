# ============================================
# Multiple RAG System — Environment Variables
# ============================================

# Google Gemini API Key (REQUIRED)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Optional: Tavily API key for enhanced web search (Corrective/Agentic RAG)
# Get a free key at: https://tavily.com
TAVILY_API_KEY=

# --- Phase 2 Infrastructure ---
DATABASE_URL=postgresql://user:password@localhost:5432/multirag
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=super-secret-key-change-in-prod

# Comma-separated frontend origins allowed by the FastAPI backend
FRONTEND_ORIGINS=http://localhost:3000
