# ============================================
# Multiple RAG System — Environment Variables
# ============================================

# Groq API Key (REQUIRED)
# Get yours for free at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Comma-separated frontend origins allowed by the FastAPI CORS middleware
# Default covers local development — override in production
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
